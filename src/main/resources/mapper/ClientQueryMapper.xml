<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.team2.master.query.mapper.ClientQueryMapper">

    <resultMap id="ClientResponseMap" type="com.team2.master.query.dto.ClientResponse">
        <result property="id"              column="client_id"/>
        <result property="clientCode"      column="client_code"/>
        <result property="clientName"      column="client_name"/>
        <result property="clientNameKr"    column="client_name_kr"/>
        <result property="countryId"       column="country_id"/>
        <result property="countryName"     column="country_name"/>
        <result property="clientCity"      column="client_city"/>
        <result property="portId"          column="port_id"/>
        <result property="portName"        column="port_name"/>
        <result property="clientAddress"   column="client_address"/>
        <result property="clientTel"       column="client_tel"/>
        <result property="clientEmail"     column="client_email"/>
        <result property="paymentTermId"   column="payment_term_id"/>
        <result property="paymentTermName" column="payment_term_name"/>
        <result property="currencyId"      column="currency_id"/>
        <result property="currencyName"    column="currency_name"/>
        <result property="clientManager"   column="client_manager"/>
        <result property="departmentId"    column="department_id"/>
        <result property="clientStatus"    column="client_status" javaType="com.team2.master.command.domain.entity.enums.ClientStatus"/>
        <result property="clientRegDate"   column="client_reg_date"/>
        <result property="createdAt"       column="created_at"/>
        <result property="updatedAt"       column="updated_at"/>
    </resultMap>

    <sql id="selectClientBase">
        SELECT
            cl.client_id,
            cl.client_code,
            cl.client_name,
            cl.client_name_kr,
            cl.country_id,
            c.country_name,
            cl.client_city,
            cl.port_id,
            p.port_name,
            cl.client_address,
            cl.client_tel,
            cl.client_email,
            cl.payment_term_id,
            pt.payment_term_name,
            cl.currency_id,
            cu.currency_name,
            cl.client_manager,
            cl.department_id,
            cl.client_status,
            cl.client_reg_date,
            cl.created_at,
            cl.updated_at
        FROM clients cl
        LEFT JOIN countries c  ON cl.country_id      = c.country_id
        LEFT JOIN ports p      ON cl.port_id          = p.port_id
        LEFT JOIN payment_terms pt ON cl.payment_term_id = pt.payment_term_id
        LEFT JOIN currencies cu    ON cl.currency_id  = cu.currency_id
    </sql>

    <select id="findById" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.client_id = #{clientId}
    </select>

    <select id="findAll" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
    </select>

    <select id="findByDepartmentId" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.department_id = #{departmentId}
    </select>

    <select id="findByClientStatus" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.client_status = #{clientStatus}
    </select>

</mapper>
