<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
  MSA 경계: master 는 auth 의 teams/departments 테이블을 직접 조인하지 않는다.
  team_id 만 조회하고 team_name/department_id/department_name 은 ClientQueryService 에서
  AuthFeignClient.getTeamsByIds 로 enrich.
-->
<mapper namespace="com.team2.master.query.mapper.ClientQueryMapper">

    <resultMap id="ClientResponseMap" type="com.team2.master.query.dto.ClientResponse">
        <result property="id"              column="client_id"/>
        <result property="clientCode"      column="client_code"/>
        <result property="clientName"      column="client_name"/>
        <result property="clientNameKr"    column="client_name_kr"/>
        <result property="countryId"       column="country_id"/>
        <result property="countryName"     column="country_name"/>
        <result property="clientCity"      column="client_city"/>
        <result property="portId"          column="port_id"/>
        <result property="portName"        column="port_name"/>
        <result property="clientAddress"   column="client_address"/>
        <result property="clientTel"       column="client_tel"/>
        <result property="clientEmail"     column="client_email"/>
        <result property="paymentTermId"   column="payment_term_id"/>
        <result property="paymentTermName" column="payment_term_name"/>
        <result property="currencyId"      column="currency_id"/>
        <result property="currencyName"    column="currency_name"/>
        <result property="clientManager"   column="client_manager"/>
        <result property="teamId"          column="team_id"/>
        <result property="clientStatus"    column="client_status"
                typeHandler="com.team2.master.config.ClientStatusTypeHandler"/>
        <result property="clientRegDate"   column="client_reg_date"/>
        <result property="createdAt"       column="created_at"/>
        <result property="updatedAt"       column="updated_at"/>
    </resultMap>

    <resultMap id="ClientListResponseMap" type="com.team2.master.query.dto.ClientListResponse">
        <result property="clientId"       column="client_id"/>
        <result property="clientCode"     column="client_code"/>
        <result property="clientName"     column="client_name"/>
        <result property="clientNameKr"   column="client_name_kr"/>
        <result property="countryName"    column="country_name"/>
        <result property="clientCity"     column="client_city"/>
        <result property="teamId"         column="team_id"/>
        <result property="clientStatus"   column="client_status"/>
        <result property="clientRegDate"  column="client_reg_date"/>
        <result property="portName"       column="port_name"/>
        <result property="clientManager"  column="client_manager"/>
        <result property="paymentTermsId" column="payment_term_id"/>
        <result property="currencyId"     column="currency_id"/>
        <result property="clientAddress"  column="client_address"/>
        <result property="clientTel"      column="client_tel"/>
        <result property="clientEmail"    column="client_email"/>
    </resultMap>

    <sql id="selectClientBase">
        SELECT
            cl.client_id,
            cl.client_code,
            cl.client_name,
            cl.client_name_kr,
            cl.country_id,
            c.country_name,
            cl.client_city,
            cl.port_id,
            p.port_name,
            cl.client_address,
            cl.client_tel,
            cl.client_email,
            cl.payment_term_id,
            pt.payment_term_name,
            cl.currency_id,
            cu.currency_name,
            cl.client_manager,
            cl.team_id,
            cl.client_status,
            cl.client_reg_date,
            cl.created_at,
            cl.updated_at
        FROM clients cl
        LEFT JOIN countries c      ON cl.country_id      = c.country_id
        LEFT JOIN ports p          ON cl.port_id         = p.port_id
        LEFT JOIN payment_terms pt ON cl.payment_term_id = pt.payment_term_id
        LEFT JOIN currencies cu    ON cl.currency_id     = cu.currency_id
    </sql>

    <sql id="clientListColumns">
        SELECT
            cl.client_id,
            cl.client_code,
            cl.client_name,
            cl.client_name_kr,
            c.country_name,
            cl.client_city,
            cl.team_id,
            cl.client_status,
            cl.client_reg_date,
            p.port_name,
            cl.client_manager,
            cl.payment_term_id,
            cl.currency_id,
            cl.client_address,
            cl.client_tel,
            cl.client_email
        FROM clients cl
        LEFT JOIN countries c   ON cl.country_id = c.country_id
        LEFT JOIN ports p       ON cl.port_id    = p.port_id
    </sql>

    <!--
      departmentId 필터는 서비스 레이어에서 auth 에 문의해 teamIds 로 변환한 뒤 teamIds IN (...) 으로 전달.
      teamIds 파라미터가 있으면 그걸로 필터, 없으면 teamId 단건.
    -->
    <sql id="clientFilterConditions">
        <where>
            <if test="clientName != null and clientName != ''">
                AND cl.client_name LIKE CONCAT('%', #{clientName}, '%')
            </if>
            <if test="countryId != null">
                AND cl.country_id = #{countryId}
            </if>
            <if test="clientStatus != null and clientStatus != ''">
                AND cl.client_status = #{clientStatus}
            </if>
            <if test="teamId != null">
                AND cl.team_id = #{teamId}
            </if>
            <if test="teamIds != null and teamIds.size() > 0">
                AND cl.team_id IN
                <foreach collection="teamIds" item="tid" open="(" separator="," close=")">
                    #{tid}
                </foreach>
            </if>
        </where>
    </sql>

    <select id="findByCondition" resultMap="ClientListResponseMap">
        <include refid="clientListColumns"/>
        <include refid="clientFilterConditions"/>
        ORDER BY cl.client_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*)
        FROM clients cl
        <include refid="clientFilterConditions"/>
    </select>

    <select id="findById" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.client_id = #{clientId}
    </select>

    <select id="findAll" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
    </select>

    <select id="findByTeamId" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.team_id = #{teamId}
    </select>

    <select id="findByTeamIds" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.team_id IN
        <foreach collection="teamIds" item="tid" open="(" separator="," close=")">
            #{tid}
        </foreach>
    </select>

    <select id="findByClientStatus" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.client_status = #{clientStatus}
    </select>

    <select id="findAllPage" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        ORDER BY cl.client_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*)
        FROM clients cl
    </select>

    <select id="findByTeamIdPage" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.team_id = #{teamId}
        ORDER BY cl.client_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countByTeamId" resultType="long">
        SELECT COUNT(*)
        FROM clients cl
        WHERE cl.team_id = #{teamId}
    </select>

    <select id="findByTeamIdsPage" resultMap="ClientResponseMap">
        <include refid="selectClientBase"/>
        WHERE cl.team_id IN
        <foreach collection="teamIds" item="tid" open="(" separator="," close=")">
            #{tid}
        </foreach>
        ORDER BY cl.client_id DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countByTeamIds" resultType="long">
        SELECT COUNT(*)
        FROM clients cl
        WHERE cl.team_id IN
        <foreach collection="teamIds" item="tid" open="(" separator="," close=")">
            #{tid}
        </foreach>
    </select>

</mapper>
